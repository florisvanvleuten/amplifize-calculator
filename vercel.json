{
  "version": 2,
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "routes": [
    {
      "src": "/calculator.html",
      "dest": "/public/calculator.html"
    },
    {
      "src": "/",
      "dest": "/public/calculator.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
